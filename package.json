{
  "name": "jogo-dificil",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write . --ignore-unknown",
    "assets:pino-sheets": "node scripts/extract-pino-frames-from-hero-examples.mjs && node scripts/generate-pino-spritesheets.mjs",
    "assets:boss-sheets": "node scripts/extract-boss-spritesheets-from-examples.mjs && node scripts/extract-boss-projectiles-from-examples.mjs",
    "assets:environment": "node scripts/generate-environment-sprites.mjs",
    "assets:block-music": "node scripts/generate-block-music-loops.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
